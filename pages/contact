<section class="aa-contact-breakout" id="contact">
  <div class="aa-contact">
    <div class="aa-contact__halo aa-contact__halo--left" aria-hidden="true"></div>
    <div class="aa-contact__halo aa-contact__halo--right" aria-hidden="true"></div>
    <div class="aa-contact__lines" aria-hidden="true"></div>
    <div class="aa-contact__dust" aria-hidden="true"></div>

    <div class="aa-contact__inner">
      <!-- Head -->
      <header class="aa-contact__head">
        <div class="aa-contact__kicker">Get In Touch</div>

        <div class="aa-contact__headGrid">
          <h2 class="aa-contact__title">Get in Touch</h2>

          <p class="aa-contact__sub">
            Tell us what you’re trying to achieve. We’ll respond quickly with a clean, brand-safe plan.
          </p>
        </div>
      </header>

      <!-- Body -->
      <div class="aa-contact__grid">
        <!-- Form Card -->
        <div class="aa-contact__card" role="region" aria-label="Contact form">
          <div class="aa-contact__cardTop">
            <div>
              <div class="aa-contact__cardTitle">Send a message</div>
              <div class="aa-contact__cardHint">We typically reply within 1 business day.</div>
            </div>

            <div class="aa-contact__badge">
              <span aria-hidden="true"></span>
              Fast reply
            </div>
          </div>

          <form class="aa-form" id="aa-contact-form">
            <div class="aa-form__row">
              <label class="aa-field">
                <span class="aa-field__label">First name</span>
                <input class="aa-field__input" type="text" name="first_name" autocomplete="given-name" placeholder="First name" required>
              </label>

              <label class="aa-field">
                <span class="aa-field__label">Last name</span>
                <input class="aa-field__input" type="text" name="last_name" autocomplete="family-name" placeholder="Last name" required>
              </label>
            </div>

            <div class="aa-form__row">
              <label class="aa-field">
                <span class="aa-field__label">Email</span>
                <input class="aa-field__input" type="email" name="email" autocomplete="email" placeholder="you@company.com" required>
              </label>

              <label class="aa-field">
                <span class="aa-field__label">Phone</span>
                <input class="aa-field__input" type="tel" name="phone" autocomplete="tel" placeholder="(000) 000-0000">
              </label>
            </div>

            <label class="aa-field">
              <span class="aa-field__label">Message</span>
              <textarea class="aa-field__input aa-field__textarea" name="message" placeholder="Tell us what you’re looking to accomplish…" required></textarea>
            </label>

            <div class="aa-form__bottom">
              <button class="aa-form__submit" type="submit">
                <span>Submit</span>
                <span class="aa-form__submitIcon" aria-hidden="true">→</span>
              </button>

              <div class="aa-form__fineprint">
                By submitting, you agree to be contacted regarding your inquiry.
              </div>
            </div>

            <div class="aa-form__status" aria-live="polite" data-aa-status></div>
          </form>
        </div>

        <!-- Info Column -->
        <aside class="aa-contact__info" aria-label="Contact details">
          <div class="aa-infoCard">
            <div class="aa-infoCard__top">
              <div class="aa-infoCard__mark" aria-hidden="true">A&amp;A</div>

              <div>
                <div class="aa-infoCard__title">We can’t wait to hear from you</div>
                <div class="aa-infoCard__subtitle">Premium partnerships, strategy, and brand-safe execution.</div>
              </div>
            </div>

            <div class="aa-infoCard__block">
              <div class="aa-infoCard__label">Office</div>
              <div class="aa-infoCard__text">
                13727 SW 152 Street, STE. #319<br>
                Miami, FL 33177
              </div>
            </div>

            <div class="aa-infoCard__block">
              <div class="aa-infoCard__label">Email</div>
              <a class="aa-infoCard__link" href="mailto:Andrew@PrimeSportsMarketing.net">Andrew@PrimeSportsMarketing.net</a>
              <a class="aa-infoCard__link" href="mailto:Gina@PrimeSportsMarketing.net">Gina@PrimeSportsMarketing.net</a>
            </div>

            <div class="aa-infoCard__block">
              <div class="aa-infoCard__label">Availability</div>
              <div class="aa-infoCard__text">
                Monday–Friday, 9am–6pm (ET)
              </div>
            </div>
          </div>

          <div class="aa-trustStrip" aria-label="Trust indicators">
            <div class="aa-trustStrip__item">
              <span class="aa-trustStrip__dot" aria-hidden="true"></span>
              <span class="aa-trustStrip__text">Brand-safe execution</span>
            </div>

            <div class="aa-trustStrip__item">
              <span class="aa-trustStrip__dot" aria-hidden="true"></span>
              <span class="aa-trustStrip__text">Premium partners</span>
            </div>

            <div class="aa-trustStrip__item">
              <span class="aa-trustStrip__dot" aria-hidden="true"></span>
              <span class="aa-trustStrip__text">Fast response time</span>
            </div>
          </div>
        </aside>
      </div>

      <!-- Bottom -->
      <div class="aa-contact__foot">
        <div class="aa-contact__note">
          Prefer a quick intro call? Send a message and we’ll propose times.
        </div>

        <a class="aa-contact__cta" href="#partners">
          View partners
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>

