      border-radius: 16px;
      padding: 0 22px;
      letter-spacing: .16em;
    }

    @media (max-width: 980px){
      #about .aa-about__inner{ grid-template-columns: 1fr; }
      #about .aa-about__left{ min-height: 0; }
    }

    @media (max-width: 640px){
      #about.aa-about-breakout .aa-about{ padding: 86px 0 82px; }
      #about .aa-about__left,
      #about .aa-about__right{ padding: 20px 16px; }
    }
  </style>

  <script>
    (function(){
      const scope = document.getElementById('about');
      if(!scope) return;

      const toReveal = [
        scope.querySelector('.aa-about__kicker'),
        scope.querySelector('.aa-about__title'),
        scope.querySelector('.aa-about__accent'),
        scope.querySelector('.aa-about__proof'),
        ...Array.from(scope.querySelectorAll('.aa-about__p')),
        scope.querySelector('.aa-about__callout'),
        scope.querySelector('.aa-about__actions')
      ].filter(Boolean);

      toReveal.forEach(el => el.classList.add('aa-reveal'));

      const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if(reduce){
        toReveal.forEach(el => el.classList.add('is-in'));
      } else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if(!entry.isIntersecting) return;
            entry.target.classList.add('is-in');
            io.unobserve(entry.target);
          });
        }, { threshold: 0.12 });

        toReveal.forEach(el => io.observe(el));
      }

      const vid = scope.querySelector('.aa-about__video');

      if(vid){
        vid.muted = true;
        vid.playsInline = true;

        const tryPlay = () => {
          const p = vid.play();
          if(p && typeof p.catch === 'function') p.catch(()=>{});
        };

        tryPlay();

        document.addEventListener('visibilitychange', () => {
          if(!document.hidden) tryPlay();
        });

        window.addEventListener('pointerdown', () => {
          tryPlay();
        }, { once:true, passive:true });

        window.addEventListener('touchstart', () => {
          tryPlay();
        }, { once:true, passive:true });
      }

      const right = scope.querySelector('.aa-about__right');
      const more = scope.querySelector('[data-aa-more]');
      const btn  = scope.querySelector('[data-aa-more-btn]');

      if(right && more && btn){
        const isMobile = () => window.matchMedia && window.matchMedia('(max-width: 640px)').matches;

        function closeMore(){
          right.classList.remove('aa-moreOpen');
          btn.setAttribute('aria-expanded','false');
          more.setAttribute('aria-hidden','true');
          more.style.maxHeight = '0px';
        }

        function openMore(){
          right.classList.add('aa-moreOpen');
          btn.setAttribute('aria-expanded','true');
          more.setAttribute('aria-hidden','false');
          more.style.maxHeight = more.scrollHeight + 'px';
        }

        function sync(){
          if(isMobile()){
            closeMore();
          } else {
            right.classList.remove('aa-moreOpen');
            btn.setAttribute('aria-expanded','true');
            more.setAttribute('aria-hidden','false');
            more.style.maxHeight = '';
          }
        }

        sync();

        btn.addEventListener('click', () => {
          if(!isMobile()) return;

          const open = right.classList.contains('aa-moreOpen');

          if(open){
            closeMore();
          } else {
            openMore();
          }
        });

        window.addEventListener('resize', () => {
          if(!isMobile()){
            sync();
            return;
          }

          if(right.classList.contains('aa-moreOpen')){
            more.style.maxHeight = more.scrollHeight + 'px';
          }
        }, { passive:true });
      }
    })();
  </script>
</section>
