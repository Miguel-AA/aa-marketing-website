<section class="aa-about-breakout" id="about">
  <div class="aa-about aa-about--hasVideo">

    <!-- Background video layer -->
    <video
      class="aa-about__video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="../resources/picturesque-helmet-buffalo-bills.jpg"
      aria-hidden="true"
    >
      <source src="../resources/knicksedit.mp4" type="video/mp4">
    </video>

    <!-- Darker scrim -->
    <div class="aa-about__scrim" aria-hidden="true"></div>

    <!-- Luxury line texture -->
    <div class="aa-about__luxLines" aria-hidden="true"></div>

    <div class="aa-about__inner">
      <!-- Left -->
      <div class="aa-about__left">
        <div class="aa-about__kicker">Who We Are</div>

        <h2 class="aa-about__title">
          WHO<br>
          WE ARE
        </h2>

        <div class="aa-about__accent" aria-hidden="true"></div>

        <div class="aa-about__proof">
          <div class="aa-proofCard">
            <div class="aa-proofCard__num">01</div>
            <div class="aa-proofCard__label">Strategy-first</div>
          </div>

          <div class="aa-proofCard">
            <div class="aa-proofCard__num">02</div>
            <div class="aa-proofCard__label">Talent-ready</div>
          </div>

          <div class="aa-proofCard">
            <div class="aa-proofCard__num">03</div>
            <div class="aa-proofCard__label">Performance-driven</div>
          </div>
        </div>
      </div>

      <!-- Right -->
      <div class="aa-about__right">
        <p class="aa-about__p">
          A&amp;A Marketing is a full-service marketing agency representing players, celebrities, and executive
          leaders in endorsement deals.
        </p>

        <div class="aa-about__more" data-aa-more aria-hidden="false">
          <p class="aa-about__p">
            Our in-house team elevates your reputation by managing communication channels and executing PR and marketing
            strategies that increase revenue and build long-term brand value.
          </p>

          <p class="aa-about__p">
            We analyze market factors, strengthen positioning, and introduce your success to the world—through media
            obligations, premium content, and opportunity creation.
          </p>

          <div class="aa-about__callout">
            <div class="aa-about__calloutIcon" aria-hidden="true"></div>
            <div class="aa-about__calloutText">
              Learning to be informative, intelligent, and entertaining in media moments—while staying brand-safe and
              strategic.
            </div>
          </div>
        </div>

        <!-- Mobile Learn More Toggle -->
        <button class="aa-about__learnMore" type="button" data-aa-more-btn aria-expanded="true">
          <span class="aa-about__learnMoreText">Learn more</span>
          <span class="aa-about__learnMoreIcon" aria-hidden="true">+</span>
        </button>

        <div class="aa-about__actions">
          <a class="aa-aboutBtn aa-aboutBtn--primary" href="#contact">Get in Touch</a>
          <a class="aa-aboutBtn aa-aboutBtn--ghost" href="#services">Explore Services</a>
        </div>
      </div>
    </div>

    <!-- Subtle dust -->
    <div class="aa-about__dust" aria-hidden="true"></div>
  </div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap');

    .aa-about-breakout{
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      width: 100vw;
    }

    /* ===== DO NOT TOUCH PADDING ===== */
    #about.aa-about-breakout .aa-about{
      position: relative;
      padding: 250px 0 72px;
      background: transparent !important;
      overflow: hidden;
      isolation: isolate;
      min-height: clamp(920px, 66vh, 760px);
    }

    /* ===== Background video ===== */
    #about .aa-about__video{
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      transform: scale(1.02);
      filter: saturate(1.03) contrast(1.00) brightness(1.08);
      z-index: 0;
      pointer-events: none;
      background: transparent !important;
    }

    /* ===== Improved scrim for better readability ===== */
    #about .aa-about__scrim{
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background:
        radial-gradient(900px 620px at 18% 40%, rgba(6,26,58,.50) 0%, rgba(6,26,58,.58) 55%, rgba(6,26,58,.70) 100%),
        linear-gradient(90deg, rgba(6,26,58,.62) 0%, rgba(11,36,77,.38) 46%, rgba(6,26,58,.54) 100%);
    }

    #about .aa-about__scrim::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(1100px 800px at 50% 55%, rgba(0,0,0,0) 0%, rgba(6,26,58,.26) 78%, rgba(6,26,58,.38) 100%);
      opacity: .95;
      pointer-events:none;
    }

    /* ===== Luxury line texture ===== */
    #about .aa-about__luxLines{
      position: absolute;
      inset: 0;
      z-index: 2;
      pointer-events: none;
      opacity: .13;
      background:
        repeating-linear-gradient(
          135deg,
          rgba(255,196,0,.16) 0px,
          rgba(255,196,0,.16) 1px,
          transparent 1px,
          transparent 22px
        );
      mask-image: radial-gradient(900px 650px at 62% 35%, black 0%, black 52%, transparent 78%);
      -webkit-mask-image: radial-gradient(900px 650px at 62% 35%, black 0%, black 52%, transparent 78%);
      mix-blend-mode: screen;
    }

    /* ===== Layout ===== */
    #about .aa-about__inner{
      position: relative;
      z-index: 3;
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 22px;
      display: grid;
      grid-template-columns: 1.05fr .95fr;
      gap: 30px;
      align-items: center;
    }

    /* ===== Left ===== */
    #about .aa-about__left{
      position: relative;
      max-width: 680px;
    }

    #about .aa-about__kicker{
      display:inline-flex;
      align-items:center;
      gap:10px;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-weight: 900;
      font-size: 12px;
      letter-spacing: .26em;
      text-transform: uppercase;
      color: rgba(245,247,250,.90);
      text-shadow: 0 10px 28px rgba(0,0,0,.36);
    }

    #about .aa-about__kicker::before{
      content:"";
      width: 28px;
      height: 2px;
      border-radius: 2px;
      background: rgba(255,196,0,.98);
      box-shadow: 0 10px 26px rgba(255,196,0,.25);
    }

    #about .aa-about__title{
      margin: 14px 0 0;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: .95;
      text-transform: uppercase;
      color: #F5F7FA;
      font-size: clamp(42px, 4.8vw, 82px);
      text-shadow:
        0 18px 54px rgba(0,0,0,.58),
        0 0 34px rgba(6,26,58,.38);
    }

    #about .aa-about__accent{
      margin-top: 14px;
      width: 72px;
      height: 6px;
      border-radius: 999px;
      background: linear-gradient(90deg, #FFC400, #FFD84D);
      box-shadow:
        0 18px 50px rgba(255,196,0,.28),
        0 0 0 1px rgba(255,196,0,.18);
      opacity: .95;
    }

    #about .aa-about__proof{
      margin-top: 18px;
      display: grid;
      grid-template-columns: repeat(3, minmax(0,1fr));
      gap: 12px;
      max-width: 560px;
    }

    #about .aa-proofCard{
      border-radius: 16px;
      border: 1px solid rgba(255,196,0,.16);
      background:
        linear-gradient(145deg, rgba(245,247,250,.09), rgba(245,247,250,.025)),
        rgba(6,26,58,.50);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      box-shadow:
        0 22px 58px rgba(0,0,0,.26),
        inset 0 1px 0 rgba(255,255,255,.06);
      padding: 13px 14px 12px;
      position: relative;
      overflow: hidden;
    }

    #about .aa-proofCard::after{
      content:"";
      position:absolute;
      inset:-50% -35% auto -35%;
      height: 150px;
      background: radial-gradient(closest-side, rgba(255,255,255,.10), rgba(255,255,255,0));
      opacity: .20;
      pointer-events:none;
    }

    #about .aa-proofCard__num{
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-weight: 900;
      letter-spacing: .12em;
      font-size: 12px;
      color: #FFC400;
      text-transform: uppercase;
    }

    #about .aa-proofCard__label{
      margin-top: 6px;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-weight: 900;
      letter-spacing: -0.02em;
      font-size: 12px;
      text-transform: uppercase;
      color: rgba(245,247,250,.95);
      line-height: 1.25;
    }

    /* ===== Right premium text card ===== */
    #about .aa-about__right{
      position: relative;
      padding: 28px;
      border-radius: 28px;
      border: 1px solid rgba(255,196,0,.16);
      background:
        linear-gradient(145deg, rgba(245,247,250,.08), rgba(245,247,250,.025)),
        rgba(6,26,58,.38);
      box-shadow:
        0 34px 90px rgba(0,0,0,.32),
        inset 0 1px 0 rgba(255,255,255,.06);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      overflow: hidden;
    }

    #about .aa-about__right::after{
      content:"";
      position:absolute;
      inset:-40% -30% auto -30%;
      height: 190px;
      background: radial-gradient(closest-side, rgba(255,255,255,.12), rgba(255,255,255,0));
      opacity:.22;
      pointer-events:none;
    }

    #about .aa-about__right > .aa-about__p,
    #about .aa-about__more,
    #about .aa-about__learnMore,
    #about .aa-about__actions{
      position: relative;
      z-index: 2;
    }

    #about .aa-about__p{
      margin: 0 0 12px;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 15.5px;
      line-height: 1.82;
      color: rgba(245,247,250,.88);
      max-width: 66ch;
      text-shadow: 0 12px 34px rgba(0,0,0,.42);
    }

    #about .aa-about__right > .aa-about__p:first-child{
      font-size: clamp(16px, 1.15vw, 18px);
      font-weight: 700;
      color: rgba(245,247,250,.94);
    }

    #about .aa-about__callout{
      margin-top: 14px;
      border-radius: 18px;
      border: 1px solid rgba(255,196,0,.22);
      background:
        linear-gradient(135deg, rgba(255,196,0,.13), rgba(245,247,250,.045)),
        rgba(6,26,58,.42);
      box-shadow:
        0 24px 62px rgba(0,0,0,.30),
        inset 0 1px 0 rgba(255,255,255,.07);
      padding: 14px 16px;
      display: grid;
      grid-template-columns: 14px 1fr;
      gap: 12px;
      align-items: start;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    #about .aa-about__calloutIcon{
      width: 14px;
      height: 14px;
      border-radius: 6px;
      margin-top: 4px;
      background: linear-gradient(135deg, #FFC400, #FFD84D);
      box-shadow: 0 14px 34px rgba(255,196,0,.20);
    }

    #about .aa-about__calloutText{
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 14px;
      line-height: 1.62;
      color: rgba(245,247,250,.94);
      font-weight: 700;
      text-shadow: 0 10px 30px rgba(0,0,0,.34);
    }

    #about .aa-about__actions{
      margin-top: 18px;
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
    }

    #about .aa-aboutBtn{
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      border-radius: 14px;
      padding: 12px 16px;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .14em;
      text-transform: uppercase;
      transition: transform .18s ease, background .18s ease, border-color .18s ease, box-shadow .18s ease, opacity .18s ease;
      white-space: nowrap;
      user-select: none;
      -webkit-tap-highlight-color: rgba(0,0,0,0);
    }

    #about .aa-aboutBtn--primary{
      background: linear-gradient(135deg, #FFC400 0%, #FFD84D 100%);
      color: #061A3A;
      border:1px solid rgba(255,196,0,.55);
      box-shadow:
        0 18px 45px rgba(0,0,0,.28),
        0 12px 34px rgba(255,196,0,.18);
    }

    #about .aa-aboutBtn--primary:hover{
      transform: translateY(-2px);
      opacity: .98;
      background:#FFD84D;
    }

    #about .aa-aboutBtn--ghost{
      color: rgba(245,247,250,.94);
      background: rgba(6,26,58,.34);
      border:1px solid rgba(255,196,0,.30);
    }

    #about .aa-aboutBtn--ghost:hover{
      transform: translateY(-2px);
      background: rgba(255,196,0,.10);
      border-color: rgba(255,196,0,.42);
      box-shadow: 0 18px 45px rgba(0,0,0,.18);
    }

    /* ===== Dust ===== */
    #about .aa-about__dust{
      position:absolute;
      inset:0;
      z-index: 2;
      pointer-events:none;
      opacity: .16;
      background-image:
        radial-gradient(circle at 12% 26%, rgba(255,196,0,.22) 0 1px, transparent 2px),
        radial-gradient(circle at 28% 68%, rgba(245,247,250,.18) 0 1px, transparent 2px),
        radial-gradient(circle at 44% 22%, rgba(255,196,0,.12) 0 1px, transparent 2px),
        radial-gradient(circle at 64% 54%, rgba(245,247,250,.16) 0 1px, transparent 2px),
        radial-gradient(circle at 78% 18%, rgba(255,196,0,.10) 0 1px, transparent 2px),
        radial-gradient(circle at 86% 72%, rgba(245,247,250,.14) 0 1px, transparent 2px);
      background-size: 520px 520px;
      filter: blur(.1px);
      transform: translateZ(0);
      mix-blend-mode: screen;
    }

    /* ===== Kill magenta focus + on-brand focus ring ===== */
    #about a:focus,
    #about a:focus-visible,
    #about button:focus,
    #about button:focus-visible{
      outline: none !important;
      box-shadow: none !important;
    }

    #about .aa-aboutBtn:focus-visible{
      box-shadow: 0 0 0 3px rgba(255,196,0,.52), 0 22px 60px rgba(0,0,0,.25) !important;
    }

    /* ===== Reveal animation ===== */
    #about .aa-reveal{
      opacity: 0;
      transform: translateY(10px);
      transition: opacity .55s ease, transform .55s ease;
    }

    #about .aa-reveal.is-in{
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce){
      #about .aa-reveal{
        opacity: 1 !important;
        transform:none !important;
        transition:none !important;
      }

      #about .aa-aboutBtn{
        transition:none !important;
      }
    }

    /* ===== Responsive ===== */
    @media (max-width: 980px){
      #about .aa-about__inner{
        grid-template-columns: 1fr;
        gap: 18px;
      }

      #about .aa-about__proof{
        grid-template-columns: repeat(3, minmax(0,1fr));
      }

      #about.aa-about-breakout .aa-about{
        min-height: auto;
      }
    }

    @media (max-width: 640px){
      #about.aa-about-breakout .aa-about{
        padding: 64px 0 62px;
      }

      #about .aa-about__proof{
        grid-template-columns: 1fr;
      }

      #about .aa-about__accent{
        width: 46px;
        height: 6px;
      }

      #about .aa-about__right{
        padding: 20px 16px;
        border-radius: 22px;
      }

      #about .aa-about__p{
        font-size: 14.5px;
        line-height: 1.72;
      }

      #about .aa-about__more{
        max-height: 0;
        overflow: hidden;
        transition: max-height .28s ease, margin-top .22s ease;
        margin-top: 0;
      }

      #about .aa-about__learnMore{
        margin: 2px 0 0;
        width: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        border: 1px solid rgba(255,196,0,.22);
        background: rgba(6,26,58,.42);
        color: rgba(245,247,250,.92);
        border-radius: 16px;
        padding: 12px 14px;
        cursor: pointer;
        -webkit-tap-highlight-color: rgba(0,0,0,0);
        user-select: none;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        position: relative;
        z-index: 2;
      }

      #about .aa-about__learnMoreText{
        font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        font-weight: 900;
        letter-spacing: .14em;
        text-transform: uppercase;
        font-size: 12px;
      }

      #about .aa-about__learnMoreIcon{
        width: 40px;
        height: 40px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255,196,0,.18);
        background: rgba(255,196,0,.06);
        font-weight: 900;
        font-size: 18px;
        line-height: 1;
        transition: transform .18s ease, background .18s ease, border-color .18s ease, box-shadow .18s ease;
      }

      #about .aa-about__right.aa-moreOpen .aa-about__more{
        margin-top: 10px;
      }

      #about .aa-about__right.aa-moreOpen .aa-about__learnMoreIcon{
        transform: rotate(45deg);
        border-color: rgba(255,196,0,.55);
        background: rgba(255,196,0,.14);
        box-shadow: 0 12px 30px rgba(255,196,0,.18);
      }
    }

    @media (min-width: 641px){
      #about .aa-about__learnMore{
        display: none;
      }

      #about .aa-about__more{
        max-height: none !important;
        overflow: visible !important;
      }
    }

