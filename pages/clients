    #clients .aa-clientDeck__media,
    #clients .aa-clientDeck__copy,
    #clients .aa-clientDeck__people{
      border:1px solid rgba(255,196,0,.20);
      background:
        linear-gradient(145deg, rgba(245,247,250,.09), rgba(245,247,250,.025) 44%),
