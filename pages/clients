    #clients .aa-clients__sub{
      margin:18px auto 0;
      max-width:720px;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size:15px;
      line-height:1.8;
      color:rgba(245,247,250,.84);
      font-weight:750;
      text-shadow:0 12px 34px rgba(0,0,0,.22);
    }

    #clients .aa-clientDeck{
      position: relative;
    }

    #clients .aa-clientDeck__stage{
      min-height: 520px;
      display:grid;
      grid-template-columns: minmax(0, .95fr) minmax(380px, .82fr);
      gap: 22px;
      align-items: stretch;
