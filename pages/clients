        radial-gradient(circle at 28% 68%, rgba(245,247,250,.18) 0 1px, transparent 2px),
        radial-gradient(circle at 48% 34%, rgba(255,196,0,.14) 0 1px, transparent 2px),
        radial-gradient(circle at 68% 72%, rgba(245,247,250,.16) 0 1px, transparent 2px),
        radial-gradient(circle at 86% 28%, rgba(255,196,0,.16) 0 1px, transparent 2px);
      background-size: 520px 520px;
      mix-blend-mode: screen;
    }

    #clients .aa-clients__inner{
      position: relative;
      z-index: 4;
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 22px;
    }

    #clients .aa-clients__head{
