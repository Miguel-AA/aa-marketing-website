    #clients .aa-clientDeck__img{
      position:absolute;
      inset:0;
      width:100%;
      height:100%;
      object-fit:cover;
      object-position:center top;
      filter:saturate(1.06) contrast(1.04);
      transform:scale(1.02);
      transition: opacity .22s ease, transform .45s ease;
    }

    #clients .aa-clientDeck__count{
      position:absolute;
      z-index:2;
      left:18px;
      bottom:18px;
      min-height:44px;
      padding:0 14px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      border-radius:14px;
      border:1px solid rgba(255,196,0,.34);
      background:rgba(6,26,58,.58);
      color:#FFC400;
      font-family:Inter, system-ui, sans-serif;
      font-size:12px;
      font-weight:900;
      letter-spacing:.18em;
      text-transform:uppercase;
      box-shadow:0 18px 45px rgba(0,0,0,.28);
    }

    #clients .aa-clientDeck__copy{
      position:relative;
      border-radius:22px;
      padding: clamp(24px, 3vw, 42px);
      overflow:hidden;
      display:flex;
      flex-direction:column;
      justify-content:center;
    }

    #clients .aa-clientDeck__copy::before{
      content:"";
      position:absolute;
      inset:-34% -30% auto -30%;
      height:220px;
      background:radial-gradient(closest-side, rgba(255,255,255,.12), rgba(255,255,255,0));
      opacity:.18;
      pointer-events:none;
    }

    #clients .aa-clientDeck__copy::after{
      content:"";
      position:absolute;
      inset:auto -40% -55% -40%;
      height:280px;
      background:radial-gradient(closest-side, rgba(255,196,0,.22), rgba(255,196,0,0));
      opacity:.42;
      pointer-events:none;
    }

    #clients .aa-clientDeck__tags,
    #clients .aa-clientDeck__name,
    #clients .aa-clientDeck__role,
    #clients .aa-clientDeck__focus{
      position:relative;
      z-index:2;
    }

    #clients .aa-clientDeck__tags{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
    }

    #clients .aa-clientTag{
      display:inline-flex;
      align-items:center;
      gap:8px;
      min-height:34px;
      padding:0 11px;
      border-radius:14px;
      border:1px solid rgba(255,196,0,.24);
      background:rgba(255,196,0,.09);
      color:rgba(245,247,250,.90);
      font-family:Inter, system-ui, sans-serif;
      font-size:11px;
      font-weight:900;
      letter-spacing:.16em;
      text-transform:uppercase;
    }

    #clients .aa-clientTag::before{
      content:"";
      width:8px;
      height:8px;
      border-radius:999px;
      background:#FFC400;
      box-shadow:0 0 0 4px rgba(255,196,0,.10);
    }

    #clients .aa-clientDeck__name{
      margin:18px 0 0;
      font-family:Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size:clamp(34px, 4vw, 64px);
      font-weight:900;
      letter-spacing:-0.05em;
      line-height:.95;
      text-transform:uppercase;
      color:#F5F7FA;
      text-shadow:0 22px 64px rgba(0,0,0,.48);
    }

    #clients .aa-clientDeck__role{
      margin:16px 0 0;
      max-width:58ch;
      font-family:Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size:15px;
      line-height:1.78;
      font-weight:700;
      color:rgba(245,247,250,.82);
    }

    #clients .aa-clientDeck__focus{
      margin-top:22px;
      display:grid;
      grid-template-columns:repeat(3, minmax(0, 1fr));
      gap:10px;
    }

    #clients .aa-clientFocus{
      min-height:72px;
      border-radius:16px;
      border:1px solid rgba(255,196,0,.16);
      background:rgba(6,26,58,.34);
      padding:12px;
      display:flex;
      flex-direction:column;
      justify-content:center;
      gap:6px;
    }

    #clients .aa-clientFocus__k{
      font-family:Inter, system-ui, sans-serif;
      color:rgba(245,247,250,.62);
      font-size:10px;
      font-weight:900;
      letter-spacing:.18em;
      text-transform:uppercase;
    }

    #clients .aa-clientFocus__v{
      font-family:Inter, system-ui, sans-serif;
      color:rgba(245,247,250,.92);
      font-size:12px;
      font-weight:900;
      line-height:1.25;
      text-transform:uppercase;
    }

    #clients .aa-clientDeck__rail{
      margin-top:18px;
      display:grid;
      grid-template-columns:48px 1fr 48px;
      gap:12px;
      align-items:stretch;
    }

    #clients .aa-clientDeck__arrow{
      min-height:64px;
      border-radius:16px;
      border:1px solid rgba(255,196,0,.24);
      background:
        linear-gradient(145deg, rgba(245,247,250,.08), rgba(245,247,250,.02)),
        rgba(6,26,58,.54);
      color:#FFC400;
      cursor:pointer;
      font-family:Inter, system-ui, sans-serif;
      font-size:18px;
      font-weight:900;
      box-shadow:0 18px 45px rgba(0,0,0,.22);
      transition:transform .18s ease, border-color .18s ease, background .18s ease;
    }

    #clients .aa-clientDeck__arrow:hover{
      transform:translateY(-2px);
      border-color:rgba(255,196,0,.48);
      background:rgba(255,196,0,.12);
    }

    #clients .aa-clientDeck__people{
      border-radius:18px;
      padding:12px;
      display:grid;
      grid-template-columns:repeat(6, minmax(0, 1fr));
      gap:10px;
    }

    #clients .aa-clientPerson{
      min-width:0;
      min-height:64px;
      border:1px solid rgba(255,196,0,.14);
      border-radius:14px;
      background:rgba(245,247,250,.045);
      color:rgba(245,247,250,.80);
      display:flex;
      align-items:center;
      gap:10px;
      padding:9px;
      cursor:pointer;
      text-align:left;
      transition:transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease;
    }

    #clients .aa-clientPerson:hover,
    #clients .aa-clientPerson.is-active{
      transform:translateY(-2px);
      border-color:rgba(255,196,0,.42);
      background:rgba(255,196,0,.10);
      box-shadow:0 18px 45px rgba(0,0,0,.20);
      color:#F5F7FA;
    }

    #clients .aa-clientPerson__thumb{
      width:42px;
      height:42px;
      border-radius:12px;
      object-fit:cover;
      object-position:center top;
      border:1px solid rgba(255,196,0,.24);
      flex:0 0 auto;
    }

    #clients .aa-clientPerson__name{
      min-width:0;
      font-family:Inter, system-ui, sans-serif;
      font-size:11px;
      line-height:1.15;
      font-weight:900;
      letter-spacing:.08em;
      text-transform:uppercase;
      overflow:hidden;
      display:-webkit-box;
      -webkit-line-clamp:2;
      -webkit-box-orient:vertical;
    }

    #clients .aa-clients__foot{
      margin-top:26px;
      padding-top:20px;
      border-top:1px solid rgba(245,247,250,.10);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      flex-wrap:wrap;
      position:relative;
    }

    #clients .aa-clients__foot::before{
      content:"";
      position:absolute;
      left:0;
      top:-1px;
      width:180px;
      height:1px;
      background:linear-gradient(90deg, rgba(255,196,0,.88), rgba(255,196,0,0));
    }

    #clients .aa-clients__note{
      font-family:Inter, system-ui, sans-serif;
      color:rgba(245,247,250,.78);
      font-size:14px;
      line-height:1.6;
      max-width:70ch;
      font-weight:700;
    }

    #clients .aa-clients__cta{
      min-height:48px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      text-decoration:none;
      border-radius:16px;
      padding:0 22px;
      font-family:Inter, system-ui, sans-serif;
      font-size:12px;
      font-weight:900;
      letter-spacing:.16em;
      text-transform:uppercase;
      color:#061A3A;
      background:linear-gradient(135deg, #FFC400 0%, #FFD84D 100%);
      border:1px solid rgba(255,196,0,.56);
      box-shadow:0 18px 45px rgba(0,0,0,.24), 0 12px 34px rgba(255,196,0,.18);
      transition:transform .18s ease, box-shadow .18s ease, opacity .18s ease;
      white-space:nowrap;
    }

    #clients .aa-clients__cta:hover{
      transform:translateY(-2px);
      opacity:.98;
      box-shadow:0 24px 60px rgba(0,0,0,.32), 0 16px 40px rgba(255,196,0,.22);
    }

    #clients, #clients *{ outline:none !important; }
    #clients a:focus, #clients a:focus-visible,
    #clients button:focus, #clients button:focus-visible{
      outline:none !important;
      box-shadow:none !important;
    }
    #clients .aa-clientDeck__arrow:focus-visible,
    #clients .aa-clientPerson:focus-visible{
      box-shadow:0 0 0 3px rgba(255,196,0,.52), 0 22px 60px rgba(0,0,0,.25) !important;
    }

    @media (max-width: 1100px){
      #clients .aa-clientDeck__people{ grid-template-columns:repeat(4, minmax(0, 1fr)); }
    }

    @media (max-width: 920px){
      #clients .aa-clientDeck__stage{ grid-template-columns:1fr; }
      #clients .aa-clientDeck__media{ min-height:420px; }
      #clients .aa-clientDeck__focus{ grid-template-columns:1fr; }
    }

    @media (max-width: 640px){
      #clients.aa-clients-breakout .aa-clients{ padding:86px 0 82px; }
      #clients .aa-clients__head{ margin-bottom:34px; }
      #clients .aa-clients__title{ font-size:clamp(32px, 10vw, 46px); }
      #clients .aa-clientDeck__media{ min-height:360px; }
      #clients .aa-clientDeck__copy{ padding:20px 16px; }
      #clients .aa-clientDeck__rail{ grid-template-columns:48px 1fr 48px; }
      #clients .aa-clientDeck__people{
        display:flex;
        overflow-x:auto;
        scroll-snap-type:x mandatory;
      }
      #clients .aa-clientPerson{
        min-width:176px;
        scroll-snap-align:start;
      }
      #clients .aa-clients__cta{ width:100%; }
    }
  </style>

  <script>
    (function(){
      const scope = document.getElementById('clients');
      if(!scope) return;

      const root = scope.querySelector('[data-aa-clients]');
      const image = scope.querySelector('[data-aa-client-img]');
      const count = scope.querySelector('[data-aa-client-count]');
      const tags = scope.querySelector('[data-aa-client-tags]');
      const name = scope.querySelector('[data-aa-client-name]');
      const role = scope.querySelector('[data-aa-client-role]');
      const focus = scope.querySelector('[data-aa-client-focus]');
      const people = scope.querySelector('[data-aa-client-people]');
      const prevBtn = scope.querySelector('[data-aa-prev]');
      const nextBtn = scope.querySelector('[data-aa-next]');
      if(!root || !image || !count || !tags || !name || !role || !focus || !people) return;

      const CLIENTS = [
        { name:"Usain Bolt", status:"Past", category:"Track & Field", role:"Global icon / Reputation, partnerships, and high-impact campaign strategy.", image:"https://primesportsmarketing.net/wp-content/uploads/2026/01/usain-bolt-6.jpg", focus:"center 18%", highlights:["PR + positioning","Brand partners","Campaign strategy"] },
        { name:"Simon Cowell", status:"Present", category:"TV / Music", role:"Television powerhouse / Media strategy, narrative control, and brand authority.", image:"https://primesportsmarketing.net/wp-content/uploads/2026/01/3eec71523b66aabd295de17c2ed5c2a04b5fc2c67c2101b9dc39d940ce2a20da-scaled.jpg", focus:"center 20%", highlights:["Media strategy","Public narrative","Brand authority"] },
        { name:"Kyle Kuzma", status:"Present", category:"NBA", role:"NBA athlete / Personal brand expansion and cultural positioning.", image:"https://primesportsmarketing.net/wp-content/uploads/2026/01/1618897.jpg", focus:"center 18%", highlights:["Content engine","Media readiness","Growth systems"] },
        { name:"Shai Gilgeous-Alexander", status:"Present", category:"NBA", role:"NBA athlete / Brand voice development and strategic visibility.", image:"https://primesportsmarketing.net/wp-content/uploads/2026/01/Shai_Gilgeous-Alexander_51815871018_cropped.jpg", focus:"center 18%", highlights:["Content strategy","Brand voice","Optimization"] },
        { name:"Deandre Ayton", status:"Present", category:"NBA", role:"NBA athlete / Partnership strategy and public market visibility.", image:"https://primesportsmarketing.net/wp-content/uploads/2026/01/AA1Uqwmw-scaled.jpg", focus:"center 18%", highlights:["Partnerships","Press moments","Brand alignment"] },
        { name:"Tichina Arnold", status:"Past", category:"Celebrity", role:"Entertainment icon / Reputation management and media readiness.", image:"https://primesportsmarketing.net/wp-content/uploads/2026/01/gettyimages-2252060352-612x612-1.jpg", focus:"center 14%", highlights:["Brand safety","Press readiness","Campaign fit"] },
        { name:"Tommy Ford", status:"Past", category:"Actor", role:"Legacy talent / Cultural impact and entertainment branding.", image:"https://primesportsmarketing.net/wp-content/uploads/2026/01/161012-tommy-mikal-ford-jsw-215p.webp", focus:"center 14%", highlights:["TV legacy","Cultural impact","Entertainment"] },
        { name:"Zion Williamson", status:"Active", category:"NBA", role:"NBA athlete / Global brand management and media strategy.", image:"https://primesportsmarketing.net/wp-content/uploads/2026/01/zion-scaled.avif", focus:"center 18%", highlights:["Global visibility","Brand protection","Partnerships"] },
        { name:"Hassan Whiteside", status:"Past", category:"NBA", role:"NBA athlete / Media relations and brand risk management.", image:"https://primesportsmarketing.net/wp-content/uploads/2026/01/hi-res-a93aeda31c0e40896d9eeac029910380_crop_north-scaled.avif", focus:"center 18%", highlights:["Media readiness","Brand safety","Partnerships"] },
        { name:"Wanda Pratt", status:"Present", category:"Public Figure", role:"Thought leadership, philanthropy, and public image strategy.", image:"https://primesportsmarketing.net/wp-content/uploads/2026/01/R.jpg", focus:"center 18%", highlights:["Public image","Media presence","Community impact"] },
        { name:"Peter Miller", status:"Present", category:"Sport Fishing", role:"Television host / Lifestyle branding and audience monetization.", image:"https://primesportsmarketing.net/wp-content/uploads/2026/01/peter-miller-for-invincible-boats-3.jpg", focus:"center", highlights:["TV presence","Championships","Lifestyle brands"] }
      ];

      people.innerHTML = CLIENTS.map((client, i) => `
        <button class="aa-clientPerson" type="button" data-aa-client="${i}" aria-label="Show ${client.name}">
          <img class="aa-clientPerson__thumb" src="${client.image}" alt="" loading="${i < 6 ? 'eager' : 'lazy'}" decoding="async" style="object-position:${client.focus || 'center'};">
          <span class="aa-clientPerson__name">${client.name}</span>
        </button>
      `).join("");

      const buttons = Array.from(people.querySelectorAll('[data-aa-client]'));
      let index = 0;
      let timer = null;
      const wrap = (i) => (i + CLIENTS.length) % CLIENTS.length;

      function setActive(nextIndex){
        index = wrap(nextIndex);
        const client = CLIENTS[index];

        image.style.opacity = '0';
        window.setTimeout(() => {
          image.src = client.image;
          image.alt = client.name;
          image.style.objectPosition = client.focus || 'center';
          image.style.opacity = '1';
        }, 120);

        count.textContent = String(index + 1).padStart(2, '0') + ' / ' + String(CLIENTS.length).padStart(2, '0');
        tags.innerHTML = `<span class="aa-clientTag">${client.status}</span><span class="aa-clientTag">${client.category}</span>`;
        name.textContent = client.name;
        role.textContent = client.role;
        focus.innerHTML = client.highlights.map((item) => `
          <div class="aa-clientFocus">
            <div class="aa-clientFocus__k">Focus</div>
            <div class="aa-clientFocus__v">${item}</div>
          </div>
        `).join("");

        buttons.forEach((button, i) => {
          button.classList.toggle('is-active', i === index);
          button.setAttribute('aria-pressed', String(i === index));
        });
      }

      function start(){
        stop();
        timer = window.setInterval(() => setActive(index + 1), 5600);
      }

      function stop(){
        if(timer) window.clearInterval(timer);
        timer = null;
      }

      people.addEventListener('click', (event) => {
        const button = event.target.closest('[data-aa-client]');
        if(!button) return;
        setActive(parseInt(button.getAttribute('data-aa-client'), 10));
        start();
      });

      if(prevBtn) prevBtn.addEventListener('click', () => { setActive(index - 1); start(); });
      if(nextBtn) nextBtn.addEventListener('click', () => { setActive(index + 1); start(); });

      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', start);

      let startX = 0;
      let dragX = 0;
      let isDown = false;
      root.addEventListener('pointerdown', (event) => {
        isDown = true;
        startX = event.clientX;
        dragX = 0;
        stop();
      });
      window.addEventListener('pointermove', (event) => {
        if(!isDown) return;
        dragX = event.clientX - startX;
      }, { passive:true });
      window.addEventListener('pointerup', () => {
        if(!isDown) return;
        isDown = false;
        if(dragX > 80) setActive(index - 1);
        else if(dragX < -80) setActive(index + 1);
        start();
      }, { passive:true });

      setActive(0);
      start();
    })();
  </script>
</section>
