      box-shadow:
        0 30px 80px rgba(0,0,0,.34),
        inset 0 1px 0 rgba(255,255,255,.07);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    #clients .aa-clientDeck__media{
      position: relative;
      min-height: 520px;
      border-radius: 22px;
      overflow:hidden;
      transform: translateZ(0);
    }

    #clients .aa-clientDeck__media::before{
      content:"";
      position:absolute;
      inset:0;
      z-index:1;
      pointer-events:none;
      background:
        linear-gradient(90deg, rgba(6,26,58,.22), rgba(6,26,58,.05) 44%, rgba(6,26,58,.72)),
        linear-gradient(180deg, rgba(6,26,58,.04), rgba(6,26,58,.70));
