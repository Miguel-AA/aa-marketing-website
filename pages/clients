<section class="aa-clients-breakout" id="clients">
  <div class="aa-clients">
    <div class="aa-clients__lines" aria-hidden="true"></div>
    <div class="aa-clients__dust" aria-hidden="true"></div>

    <div class="aa-clients__inner">
      <header class="aa-clients__head">
        <div class="aa-clients__kicker">Our Clients</div>
        <h2 class="aa-clients__title">Past &amp; Present Spotlight Roster</h2>
        <p class="aa-clients__sub">
          Select partnerships across athletes, celebrities, and public figures. Built to protect reputation and grow outcomes.
        </p>
      </header>

      <div class="aa-clientDeck" data-aa-clients>
        <div class="aa-clientDeck__stage" aria-live="polite">
          <div class="aa-clientDeck__media">
            <img class="aa-clientDeck__img" data-aa-client-img alt="" loading="eager" decoding="async">
            <div class="aa-clientDeck__count" data-aa-client-count>01 / 01</div>
          </div>

          <div class="aa-clientDeck__copy">
            <div class="aa-clientDeck__tags" data-aa-client-tags></div>
            <h3 class="aa-clientDeck__name" data-aa-client-name></h3>
            <p class="aa-clientDeck__role" data-aa-client-role></p>
            <div class="aa-clientDeck__focus" data-aa-client-focus></div>
          </div>
        </div>

        <div class="aa-clientDeck__rail">
          <button class="aa-clientDeck__arrow" type="button" data-aa-prev aria-label="Previous client">&larr;</button>
          <div class="aa-clientDeck__people" data-aa-client-people aria-label="Client selector"></div>
          <button class="aa-clientDeck__arrow" type="button" data-aa-next aria-label="Next client">&rarr;</button>
        </div>
      </div>

      <div class="aa-clients__foot">
        <div class="aa-clients__note">Need a media-ready brand system around your goals? We can build the plan.</div>
        <a class="aa-clients__cta" href="#contact">Request a consultation</a>
      </div>
    </div>
  </div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap');

    .aa-clients-breakout{
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      width: 100vw;
    }

    #clients.aa-clients-breakout .aa-clients{
      position: relative;
      padding: 110px 0 104px;
      overflow: hidden;
      isolation: isolate;
      background:
        linear-gradient(180deg, rgba(6,26,58,.96) 0%, rgba(6,26,58,.72) 22%, rgba(6,26,58,.86) 100%),
        linear-gradient(140deg, rgba(255,196,0,.08), rgba(255,196,0,0) 48%),
        url("../resources/thecourt.jpg") center/cover no-repeat;
    }

    #clients.aa-clients-breakout .aa-clients::before{
      content:"";
      position:absolute;
      inset:0;
      z-index:0;
      pointer-events:none;
      background:
        radial-gradient(circle at 16% 20%, rgba(255,196,0,.12), transparent 24%),
        radial-gradient(circle at 82% 24%, rgba(255,255,255,.08), transparent 18%),
        radial-gradient(circle at 50% 88%, rgba(0,0,0,.32), transparent 42%);
    }

    #clients.aa-clients-breakout .aa-clients::after{
      content:"";
      position:absolute;
      z-index:0;
      pointer-events:none;
      inset: 0;
      display: none;
    }

    #clients .aa-clients__lines{
      position:absolute;
      inset:0;
      z-index:1;
      pointer-events:none;
      opacity:.18;
      background:
        repeating-linear-gradient(135deg, rgba(255,196,0,.18) 0px, rgba(255,196,0,.18) 1px, transparent 1px, transparent 24px),
        repeating-linear-gradient(45deg, rgba(245,247,250,.045) 0px, rgba(245,247,250,.045) 1px, transparent 1px, transparent 42px);
      mask-image: radial-gradient(900px 650px at 62% 34%, black 0%, black 54%, transparent 78%);
      -webkit-mask-image: radial-gradient(900px 650px at 62% 34%, black 0%, black 54%, transparent 78%);
      mix-blend-mode: screen;
    }

    #clients .aa-clients__dust{
      position:absolute;
      inset:0;
      z-index:1;
      pointer-events:none;
      opacity:.18;
      background-image:
