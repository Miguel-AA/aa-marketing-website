      overflow: hidden;
      border-right: 0;
      border-bottom: 1px solid rgba(245,247,250,.08);
      background: #061A3A;
    }

    #team .aa-teamCard__photo{
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      filter: saturate(1.03) contrast(1.03);
      transform: scale(1.01);
      transition: transform .28s ease;
    }

    #team .aa-teamCard:hover .aa-teamCard__photo{
      transform: scale(1.04);
    }

    #team .aa-teamCard__media::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(180deg, rgba(6,26,58,.05), rgba(6,26,58,.56)),
