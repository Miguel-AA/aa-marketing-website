    #team .aa-team__grid{
      margin-top: 24px;
      display:grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
      align-items: stretch;
    }

    #team .aa-teamCard,
    #team .aa-teamCard--featured{
      grid-column: auto;
      display:flex;
      flex-direction:column;
      min-height: 0;
      border-radius: 20px;
      border:1px solid rgba(255,196,0,.18);
      background:
        linear-gradient(145deg, rgba(245,247,250,.075), rgba(245,247,250,.025) 46%),
        rgba(6,26,58,.60);
      box-shadow:
        0 22px 56px rgba(0,0,0,.28),
        inset 0 1px 0 rgba(255,255,255,.06);
      overflow:hidden;
      position: relative;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      transition: transform .22s ease, border-color .22s ease, box-shadow .22s ease;
    }

    #team .aa-teamCard::before{
      content:"";
      position:absolute;
      inset:-35% -28% auto -28%;
      height: 170px;
      background: radial-gradient(closest-side, rgba(255,255,255,.08), rgba(255,255,255,0));
      opacity: .12;
      pointer-events:none;
    }

    #team .aa-teamCard:hover{
      transform: translateY(-3px);
      border-color: rgba(255,196,0,.34);
      box-shadow:
        0 30px 72px rgba(0,0,0,.36),
        0 0 52px rgba(255,196,0,.09),
        inset 0 1px 0 rgba(255,255,255,.07);
    }

    #team .aa-teamCard__media{
