  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap');

    .aa-team-breakout{
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      width: 100vw;
    }

    #team.aa-team-breakout .aa-team{
      position: relative;
      padding: 78px 0 78px;
      background:
        linear-gradient(180deg, rgba(6,26,58,.96) 0%, rgba(6,26,58,.72) 22%, rgba(6,26,58,.86) 100%),
        linear-gradient(140deg, rgba(255,196,0,.08), rgba(255,196,0,0) 48%),
        url("../resources/thecouch.jpg") center/cover no-repeat;
      overflow: hidden;
      isolation: isolate;
    }

    #team.aa-team-breakout .aa-team::before{
      content:"";
      position:absolute;
      inset:0;
      z-index:0;
      pointer-events:none;
      background:
        radial-gradient(circle at 16% 20%, rgba(255,196,0,.12), transparent 24%),
        radial-gradient(circle at 82% 24%, rgba(255,255,255,.08), transparent 18%),
        radial-gradient(circle at 50% 88%, rgba(0,0,0,.32), transparent 42%);
    }

    #team.aa-team-breakout .aa-team::after{
      content:"";
      position:absolute;
      z-index:0;
      pointer-events:none;
      inset: 0;
      display: none;
    }

    #team .aa-team__inner{
      position: relative;
      z-index: 2;
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 22px;
    }

    #team .aa-team__bg{
      position:absolute;
      inset:0;
      z-index:0;
      pointer-events:none;
      background:
        radial-gradient(740px 420px at 18% 20%, rgba(255,196,0,.14), transparent 62%),
        radial-gradient(760px 420px at 82% 56%, rgba(245,247,250,.06), transparent 60%);
      opacity: .42;
      mix-blend-mode: screen;
    }

    #team .aa-team__lines{
      position:absolute;
      inset:0;
      z-index:1;
      pointer-events:none;
      opacity:.14;
      background:
        repeating-linear-gradient(135deg, rgba(255,196,0,.15) 0px, rgba(255,196,0,.15) 1px, transparent 1px, transparent 24px),
        repeating-linear-gradient(45deg, rgba(245,247,250,.04) 0px, rgba(245,247,250,.04) 1px, transparent 1px, transparent 42px);
      mask-image: radial-gradient(800px 560px at 55% 30%, black 0%, black 52%, transparent 78%);
      -webkit-mask-image: radial-gradient(800px 560px at 55% 30%, black 0%, black 52%, transparent 78%);
      mix-blend-mode: screen;
    }

    #team .aa-team__dust{
      position:absolute;
      inset:0;
      z-index:1;
      pointer-events:none;
      opacity:.14;
      background-image:
        radial-gradient(circle at 12% 24%, rgba(255,196,0,.22) 0 1px, transparent 2px),
        radial-gradient(circle at 28% 68%, rgba(245,247,250,.16) 0 1px, transparent 2px),
        radial-gradient(circle at 48% 34%, rgba(255,196,0,.12) 0 1px, transparent 2px),
        radial-gradient(circle at 68% 72%, rgba(245,247,250,.14) 0 1px, transparent 2px),
        radial-gradient(circle at 86% 28%, rgba(255,196,0,.14) 0 1px, transparent 2px);
      background-size: 520px 520px;
      mix-blend-mode: screen;
    }

    #team .aa-team__head{
      position: relative;
      max-width: 780px;
      margin: 0 auto 36px;
      text-align: center;
    }

    #team .aa-team__head::after{
      content:"";
      position:absolute;
      left:50%;
      bottom:-18px;
      width:min(460px, 80vw);
      height:1px;
      transform:translateX(-50%);
      background:linear-gradient(90deg, transparent, rgba(255,196,0,.62), transparent);
      box-shadow:0 0 26px rgba(255,196,0,.18);
    }

