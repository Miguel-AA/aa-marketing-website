/* FULL-CARD TEAM PHOTOS */
#team .aa-teamCard__media{
  position: relative;
  overflow: hidden;
  border-right: 1px solid rgba(245,247,250,.08);
  background: #061A3A;
}

/* Image fills entire media column */
#team .aa-teamCard__photo{
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;      /* ensures uniform cropping */
  object-position: center top; /* keeps faces higher in frame */
  filter: saturate(1.02) contrast(1.02);
  transform: scale(1.01);
}

/* Subtle overlay for text contrast */
#team .aa-teamCard__media::after{
  content:"";
  position:absolute;
  inset:0;
  background:
    linear-gradient(
      to bottom,
      rgba(6,26,58,.10),
      rgba(6,26,58,.35)
    );
  pointer-events:none;
}

/* Keep badge above photo */
#team .aa-teamCard__badge{
  z-index: 2;
}

#team .aa-teamCard__initials{
  display: none !important;
}

@media (max-width: 640px){
  #team .aa-teamCard__media{
    height: 300px;
    border-right: 0;
    border-bottom: 1px solid rgba(245,247,250,.08);
  }
}

/* ===== Premium refresh: editorial team cards ===== */
#team .aa-team__head{
  position: relative;
  max-width: 900px;
  margin: 0 auto 42px;
  text-align: center;
}

#team .aa-team__head::after{
  content:"";
  position:absolute;
  left:50%;
