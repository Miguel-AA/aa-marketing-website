    #team .aa-team__cta:hover{ transform: translateY(-2px); opacity:.98; }

    /* Kill magenta focus */
    #team, #team *{ outline: none !important; }
    #team a:focus, #team a:focus-visible,
    #team button:focus, #team button:focus-visible{ outline: none !important; box-shadow:none !important; }
    #team .aa-teamCard__btn:focus-visible{
      box-shadow: 0 0 0 3px rgba(255,196,0,.52), 0 22px 60px rgba(0,0,0,.25) !important;
    }

    /* Responsive */
    @media (max-width: 1100px){
      #team .aa-teamCard{ grid-column: span 12; }
