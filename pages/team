  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap');

    /* Full-width breakout */
    .aa-team-breakout{
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
      width: 100vw;
    }

    #team.aa-team-breakout .aa-team{
      position: relative;
      padding: 110px 0 104px;
      background:
        radial-gradient(900px 520px at 12% 18%, rgba(255,196,0,.16), transparent 62%),
        radial-gradient(720px 460px at 88% 22%, rgba(245,247,250,.09), transparent 64%),
        radial-gradient(760px 520px at 50% 88%, rgba(255,196,0,.10), transparent 68%),
        linear-gradient(180deg, rgba(6,26,58,.98) 0%, rgba(4,18,42,.96) 45%, rgba(3,13,31,.98) 100%) !important;
      overflow: hidden;
      isolation: isolate;
    }

    #team.aa-team-breakout .aa-team::before{
      content:"";
      position:absolute;
      inset:0;
      z-index:0;
      pointer-events:none;
      background:
        radial-gradient(900px 620px at 50% 42%, rgba(255,255,255,.045), transparent 65%),
        linear-gradient(90deg, rgba(0,0,0,.20) 0%, transparent 18%, transparent 82%, rgba(0,0,0,.22) 100%),
        linear-gradient(180deg, rgba(0,0,0,.16) 0%, transparent 32%, rgba(0,0,0,.28) 100%);
    }

    #team.aa-team-breakout .aa-team::after{
      content:"";
      position:absolute;
      z-index:0;
      pointer-events:none;
      width: 980px;
      height: 980px;
      right: -360px;
      top: -260px;
      border-radius: 999px;
      background:
        conic-gradient(
          from 210deg,
          rgba(255,196,0,0) 0deg,
          rgba(255,196,0,.16) 48deg,
          rgba(255,255,255,.06) 92deg,
          rgba(255,196,0,0) 150deg,
          rgba(255,196,0,0) 360deg
        );
      filter: blur(8px);
      opacity: .72;
      transform: rotate(-8deg);
    }

    #team .aa-team__inner{
      position: relative;
      z-index: 4;
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 22px;
    }

    /* Ambient BG */
    #team .aa-team__bg{
      position:absolute; inset:0; z-index:0; pointer-events:none;
      background:
        radial-gradient(900px 520px at 18% 20%, rgba(255,196,0,.18), transparent 62%),
        radial-gradient(860px 520px at 82% 56%, rgba(245,247,250,.08), transparent 60%);
      opacity: .45;
      mix-blend-mode: screen;
    }

    /* subtle texture */
    #team .aa-team__lines{
      position:absolute; inset:0; z-index:1; pointer-events:none; opacity:.18;
      background:
        repeating-linear-gradient(135deg, rgba(255,196,0,.18) 0px, rgba(255,196,0,.18) 1px, transparent 1px, transparent 24px),
        repeating-linear-gradient(45deg, rgba(245,247,250,.045) 0px, rgba(245,247,250,.045) 1px, transparent 1px, transparent 42px);
      mask-image: radial-gradient(900px 650px at 55% 30%, black 0%, black 52%, transparent 78%);
      -webkit-mask-image: radial-gradient(900px 650px at 55% 30%, black 0%, black 52%, transparent 78%);
      mix-blend-mode: screen;
    }
    #team .aa-team__dust{
      position:absolute; inset:0; z-index:1; pointer-events:none; opacity:.18;
      background-image:
        radial-gradient(circle at 12% 24%, rgba(255,196,0,.24) 0 1px, transparent 2px),
        radial-gradient(circle at 28% 68%, rgba(245,247,250,.18) 0 1px, transparent 2px),
        radial-gradient(circle at 48% 34%, rgba(255,196,0,.14) 0 1px, transparent 2px),
        radial-gradient(circle at 68% 72%, rgba(245,247,250,.16) 0 1px, transparent 2px),
        radial-gradient(circle at 86% 28%, rgba(255,196,0,.16) 0 1px, transparent 2px);
      background-size: 520px 520px;
      mix-blend-mode: screen;
    }

    /* Header */
    #team .aa-team__head{ max-width: 920px; margin-bottom: 34px; }
    #team .aa-team__kicker{
      display:inline-flex; align-items:center; gap:10px;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-weight: 900; font-size: 12px; letter-spacing: .26em;
      text-transform: uppercase; color: rgba(245,247,250,.90);
      text-shadow: 0 12px 34px rgba(0,0,0,.38);
    }
    #team .aa-team__kicker::before{
      content:""; width:28px; height:2px; border-radius:2px;
      background: rgba(255,196,0,.98);
      box-shadow: 0 10px 26px rgba(255,196,0,.25);
    }
    #team .aa-team__title{
      margin: 16px 0 0;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-weight: 950;
      letter-spacing: -0.03em;
      line-height: 1.02;
      font-size: clamp(30px, 3.8vw, 58px);
      color: rgba(245,247,250,.94);
      text-transform: uppercase;
      text-shadow: 0 18px 54px rgba(0,0,0,.45);
    }
    #team .aa-team__sub{
      margin: 16px 0 0;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 15px; line-height: 1.85;
      color: rgba(245,247,250,.80);
      max-width: 78ch;
      text-shadow: 0 14px 40px rgba(0,0,0,.30);
    }

    /* Redesigned Grid:
       - Top row: 2 featured cards
       - Next rows: clean compact cards
    */
    #team .aa-team__grid{
      margin-top: 26px;
      display:grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 18px;
      align-items: stretch;
    }

    /* Card base */
    #team .aa-teamCard{
      grid-column: span 6;
      border-radius: 26px;
      border: 1px solid rgba(245,247,250,.10);
      background: linear-gradient(180deg, rgba(6,26,58,.34), rgba(6,26,58,.20));
      box-shadow: 0 26px 70px rgba(0,0,0,.22);
      overflow:hidden;
      position: relative;
      display:grid;
      grid-template-columns: 260px 1fr;
      min-height: 240px;
      transition: transform .18s ease, border-color .18s ease, box-shadow .18s ease;
    }

    /* subtle corner glow */
    #team .aa-teamCard::before{
      content:"";
      position:absolute; inset:-40% -30% auto -30%;
      height: 210px;
      background: radial-gradient(closest-side, rgba(255,255,255,.10), rgba(255,255,255,0));
      opacity: .14;
      pointer-events:none;
    }

    /* Featured cards: stronger edge + deeper glow */
    #team .aa-teamCard--featured{
      border-color: rgba(255,196,0,.28);
      box-shadow: 0 34px 90px rgba(0,0,0,.26);
    }
    #team .aa-teamCard--featured::after{
      content:"";
      position:absolute; inset:auto -20% -35% -20%;
      height: 220px;
      background: radial-gradient(closest-side, rgba(255,196,0,.22), transparent 70%);
      opacity:.75;
      pointer-events:none;
      filter: blur(2px);
    }

    /* Hover */
    #team .aa-teamCard:hover{
      transform: translateY(-2px);
      border-color: rgba(255,196,0,.24);
      box-shadow: 0 34px 92px rgba(0,0,0,.26);
    }
    #team .aa-teamCard--featured:hover{
      border-color: rgba(255,196,0,.36);
      box-shadow: 0 42px 110px rgba(0,0,0,.30);
    }

    /* Media */
    #team .aa-teamCard__media{
      position: relative;
      border-right: 1px solid rgba(245,247,250,.08);
      overflow:hidden;
      display:flex;
      align-items:center;
      justify-content:center;
      background:
        radial-gradient(170px 170px at 50% 42%, rgba(245,247,250,.10), transparent 72%),
        rgba(255,196,0,.04);
    }

    /* rank badge */
    #team .aa-teamCard__badge{
      position:absolute;
      top: 14px;
      left: 14px;
      padding: 8px 10px;
      border-radius: 14px;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-weight: 950;
      font-size: 11px;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: rgba(245,247,250,.92);
      border: 1px solid rgba(255,196,0,.34);
      background: rgba(255,196,0,.14);
      box-shadow: 0 18px 44px rgba(0,0,0,.24);
      user-select:none;
    }
    #team .aa-teamCard__badge--muted{
      border-color: rgba(245,247,250,.14);
      background: rgba(6,26,58,.28);
      color: rgba(245,247,250,.84);
    }

    /* Initials */
    #team .aa-teamCard__initials{
      width: 118px;
      height: 118px;
      border-radius: 999px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-weight: 950;
      font-size: 38px;
      letter-spacing: .08em;
      color: rgba(6,26,58,.95);
      background: linear-gradient(135deg, rgba(255,196,0,.96), rgba(255,216,77,.96));
      box-shadow:
        0 22px 60px rgba(0,0,0,.34),
        inset 0 0 0 1px rgba(255,255,255,.18);
      text-transform: uppercase;
      user-select: none;
    }

    /* Body */
    #team .aa-teamCard__body{
      padding: 22px 22px 18px;
      display:flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 14px;
      position: relative;
      z-index: 2;
    }

    #team .aa-teamCard__top{
      display:flex;
      flex-direction: column;
      gap: 8px;
    }

    #team .aa-teamCard__name{
      margin: 0;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-weight: 950;
      letter-spacing: -0.02em;
      text-transform: uppercase;
      color: rgba(245,247,250,.95);
      font-size: clamp(18px, 2vw, 26px);
      line-height: 1.08;
      text-shadow: 0 14px 44px rgba(0,0,0,.36);
    }

    #team .aa-teamCard__role{
      margin: 0;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 12.5px;
      font-weight: 950;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: rgba(245,247,250,.76);
      display:flex;
      align-items:center;
      gap:10px;
    }
    #team .aa-teamCard__role::before{
      content:"";
      width: 8px; height: 8px; border-radius:999px;
      background: rgba(255,196,0,.95);
      box-shadow: 0 12px 28px rgba(255,196,0,.20);
      flex: 0 0 auto;
    }

    /* Actions */
    #team .aa-teamCard__actions{
      display:flex;
      align-items:center;
      justify-content: space-between;
      gap: 14px;
      padding-top: 14px;
      border-top: 1px solid rgba(245,247,250,.08);
    }

    #team .aa-teamCard__btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      text-decoration:none;
      border: 1px solid rgba(255,196,0,.20);
      background: rgba(6,26,58,.28);
      color: rgba(245,247,250,.92);
      border-radius: 14px;
      padding: 10px 14px;
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 12px;
      font-weight: 950;
      letter-spacing: .16em;
      text-transform: uppercase;
      transition: transform .18s ease, background .18s ease, border-color .18s ease, box-shadow .18s ease, opacity .18s ease;
      -webkit-tap-highlight-color: rgba(0,0,0,0);
      white-space: nowrap;
    }
    #team .aa-teamCard__btn:hover{
      transform: translateY(-2px);
      background: rgba(255,196,0,.10);
      border-color: rgba(255,196,0,.34);
      box-shadow: 0 18px 45px rgba(0,0,0,.20);
    }

    #team .aa-teamCard__pill{
      display:inline-flex;
      align-items:center;
      gap: 8px;
      padding: 8px 10px;
      border-radius: 12px;
      border: 1px solid rgba(255,196,0,.28);
      background: rgba(255,196,0,.10);
      color: rgba(245,247,250,.90);
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 11px;
      font-weight: 950;
      letter-spacing: .18em;
      text-transform: uppercase;
      user-select:none;
      white-space: nowrap;
    }

    /* Footer */
    #team .aa-team__foot{
      margin-top: 34px;
      padding-top: 22px;
      border-top: 1px solid rgba(245,247,250,.10);
      display:flex;
