  <script>
    (function(){
      const scope = document.getElementById('facts');
      if(!scope) return;

      const prefersReduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const cards = Array.from(scope.querySelectorAll('[data-aa-stat]'));
      if(!cards.length) return;

      const fmt = (n) => {
        try {
          return new Intl.NumberFormat('en-US').format(n);
        } catch(e) {
          return String(n).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }
      };

      function animate(el, to){
        const numEl = el.querySelector('[data-aa-num]');
        if(!numEl) return;

        if(prefersReduce){
          numEl.textContent = fmt(to);
          return;
        }

        const dur = 1200;
        const start = performance.now();
        const from = 0;

        const tick = (t) => {
          const p = Math.min(1, (t - start) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          const val = Math.round(from + (to - from) * eased);
          numEl.textContent = fmt(val);
          if(p < 1) requestAnimationFrame(tick);
        };

        requestAnimationFrame(tick);
      }

      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if(!e.isIntersecting) return;

          const el = e.target;
          if(el.__aaDone) return;

          el.__aaDone = true;
          const to = parseInt(el.getAttribute('data-aa-value') || '0', 10);
          animate(el, to);
          io.unobserve(el);
        });
      }, { threshold: 0.35 });

      cards.forEach(c => io.observe(c));
    })();
  </script>
