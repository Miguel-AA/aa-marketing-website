    #partners .aa-partners2__cta{
      min-height:48px;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      text-decoration:none;
      border-radius:16px;
      padding:0 22px;
      font-family:Inter, system-ui, sans-serif;
      font-size:12px;
      font-weight:900;
      letter-spacing:.16em;
      text-transform:uppercase;
      color:#061A3A;
      background:linear-gradient(135deg, #FFC400 0%, #FFD84D 100%);
      border:1px solid rgba(255,196,0,.56);
      box-shadow:0 18px 45px rgba(0,0,0,.24), 0 12px 34px rgba(255,196,0,.18);
