  <script>
    (function(){
      const scope = document.getElementById('partners');
      if(!scope) return;

      const root = scope.querySelector('[data-aa-partners2]');
      const miniRow = scope.querySelector('[data-aa-minirow]');
      const logo = scope.querySelector('[data-aa-partner-logo]');
      const tag = scope.querySelector('[data-aa-partner-tag]');
      const name = scope.querySelector('[data-aa-partner-name]');
      const desc = scope.querySelector('[data-aa-partner-desc]');
      const bar = scope.querySelector('[data-aa-bar]');
      const prevBtn = scope.querySelector('[data-aa-prev]');
      const nextBtn = scope.querySelector('[data-aa-next]');
      if(!root || !miniRow || !logo || !tag || !name || !desc || !bar) return;

      const PARTNERS = [
        { name:"Hublot", tag:"Luxury", logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Hublot%20logo.svg", desc:"Premium positioning and brand storytelling for elite talent." },
        { name:"Puma", tag:"Sportswear", logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Puma-logo-%28text%29.svg", desc:"Performance-driven lifestyle activations and global campaigns." },
        { name:"Nissan", tag:"Automotive", logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Nissan_2020_logo.svg", desc:"Automotive collaborations and large-scale brand activations." },
        { name:"Pepsi", tag:"Beverage", logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Pepsi_logo_%282014%29.svg", desc:"Global consumer campaigns and high-reach sponsorship exposure." },
        { name:"Gatorade", tag:"Sports Drink", logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Gatorade_logo.svg", desc:"Global performance partnerships and athlete activations." },
        { name:"Gibson", tag:"Music", logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Gibson_logo.svg", desc:"Iconic culture partnerships and premium storytelling moments." },
        { name:"Zoom", tag:"Technology", logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Zoom_Logo_2022.svg", desc:"Communications partner for campaigns and live collaborations." },
        { name:"Digicel", tag:"Telecom", logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Digicel_logo.svg", desc:"Regional brand activations and high-reach media exposure." },
        {
          name:"Celldration",
          tag:"Hydration",
          logo:"data:image/svg+xml;utf8," + encodeURIComponent('<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"900\" height=\"240\" viewBox=\"0 0 900 240\"><text x=\"12\" y=\"138\" font-family=\"Arial\" font-weight=\"900\" font-size=\"86\"><tspan fill=\"#061A3A\">CELL</tspan><tspan fill=\"#FFC400\">DRATION</tspan></text></svg>'),
          desc:"Consumer campaigns and endorsement alignment."
        }
      ];

      miniRow.innerHTML = PARTNERS.map((partner, i) => `
        <button class="aa-partnerTile" type="button" data-aa-mini="${i}" aria-label="Show ${partner.name}">
          <img class="aa-partnerTile__logo" src="${partner.logo}" alt="" loading="${i < 6 ? 'eager' : 'lazy'}" decoding="async">
          <span class="aa-partnerTile__name">${partner.name}</span>
        </button>
      `).join("");

      const tiles = Array.from(miniRow.querySelectorAll('[data-aa-mini]'));
      let index = 0;
      let timer = null;
      const wrap = (i) => (i + PARTNERS.length) % PARTNERS.length;

      function setActive(nextIndex){
        index = wrap(nextIndex);
        const partner = PARTNERS[index];

        logo.style.opacity = '0';
        logo.style.transform = 'scale(.96)';
        window.setTimeout(() => {
          logo.src = partner.logo;
          logo.alt = partner.name + ' logo';
          logo.style.opacity = '1';
          logo.style.transform = 'scale(1)';
        }, 120);

        tag.textContent = partner.tag;
        name.textContent = partner.name;
        desc.textContent = partner.desc;
        bar.style.width = ((index + 1) / PARTNERS.length * 100) + '%';

        tiles.forEach((tile, i) => {
          tile.classList.toggle('is-active', i === index);
          tile.setAttribute('aria-pressed', String(i === index));
        });
      }

      function start(){
        stop();
        timer = window.setInterval(() => setActive(index + 1), 5400);
      }

      function stop(){
        if(timer) window.clearInterval(timer);
        timer = null;
      }

      miniRow.addEventListener('click', (event) => {
        const button = event.target.closest('[data-aa-mini]');
        if(!button) return;
        setActive(parseInt(button.getAttribute('data-aa-mini'), 10));
        start();
      });

      if(prevBtn) prevBtn.addEventListener('click', () => { setActive(index - 1); start(); });
      if(nextBtn) nextBtn.addEventListener('click', () => { setActive(index + 1); start(); });

      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', start);

      setActive(0);
      start();
    })();
  </script>
</section>
