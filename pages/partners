      text-transform:uppercase;
      color:rgba(245,247,250,.86);
      text-align:center;
    }

    #partners .aa-partnerBoard__feature{
      border-radius:22px;
      padding:22px;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      gap:18px;
      overflow:hidden;
      position:relative;
    }

    #partners .aa-partnerBoard__feature::before{
      content:"";
      position:absolute;
      inset:-34% -30% auto -30%;
      height:220px;
      background:radial-gradient(closest-side, rgba(255,255,255,.12), rgba(255,255,255,0));
      opacity:.18;
      pointer-events:none;
    }

    #partners .aa-partnerBoard__label{
      position:relative;
      z-index:2;
      font-family:Inter, system-ui, sans-serif;
      color:rgba(255,196,0,.90);
      font-size:11px;
      font-weight:900;
      letter-spacing:.22em;
      text-transform:uppercase;
    }

    #partners .aa-partnerBoard__logoStage{
      position:relative;
      z-index:2;
      min-height:190px;
      border-radius:18px;
