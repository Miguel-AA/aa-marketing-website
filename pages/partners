    #partners .aa-partnerTile:hover,
    #partners .aa-partnerTile.is-active{
      transform:translateY(-4px);
      border-color:rgba(255,196,0,.46);
      background:rgba(255,196,0,.10);
      box-shadow:0 22px 58px rgba(0,0,0,.28), 0 0 70px rgba(255,196,0,.12);
