<section class="aa-partners2-breakout" id="partners">
  <div class="aa-partners2">
    <div class="aa-partners2__lines" aria-hidden="true"></div>
    <div class="aa-partners2__dust" aria-hidden="true"></div>

    <div class="aa-partners2__inner">
      <header class="aa-partners2__head">
        <div class="aa-partners2__kicker">Our Partners</div>
        <h2 class="aa-partners2__title">Brand Board</h2>
        <p class="aa-partners2__sub">
          Premium partner relationships arranged for fast scanning, quick selection, and a more original experience.
        </p>
      </header>

      <div class="aa-partnerBoard" data-aa-partners2>
        <div class="aa-partnerBoard__logos" data-aa-minirow aria-label="Partner selector"></div>

        <div class="aa-partnerBoard__feature" aria-live="polite">
          <div class="aa-partnerBoard__label">Selected Partner</div>
          <div class="aa-partnerBoard__logoStage">
            <img class="aa-partnerBoard__logo" data-aa-partner-logo alt="" loading="eager" decoding="async">
          </div>
          <div class="aa-partnerBoard__copy">
            <div class="aa-partnerBoard__tag" data-aa-partner-tag></div>
            <h3 class="aa-partnerBoard__name" data-aa-partner-name></h3>
            <p class="aa-partnerBoard__desc" data-aa-partner-desc></p>
          </div>

          <div class="aa-partnerBoard__nav">
            <button class="aa-partnerBoard__arrow" type="button" data-aa-prev aria-label="Previous partner">&larr;</button>
            <div class="aa-partnerBoard__meter" aria-label="Partner progress">
              <div class="aa-partnerBoard__bar" data-aa-bar></div>
            </div>
            <button class="aa-partnerBoard__arrow" type="button" data-aa-next aria-label="Next partner">&rarr;</button>
          </div>
        </div>
      </div>

      <div class="aa-partners2__foot">
        <div class="aa-partners2__note">
          Interested in partnership opportunities? We build clean, brand-safe campaigns with premium execution.
        </div>
        <a class="aa-partners2__cta" href="#contact">Request a consultation</a>
      </div>
    </div>
  </div>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800;900&display=swap');

    .aa-partners2-breakout{
      position:relative;
      left:50%;
      right:50%;
      margin-left:-50vw;
      margin-right:-50vw;
      width:100vw;
    }

    #partners.aa-partners2-breakout .aa-partners2{
      position:relative;
      padding:110px 0 104px;
      overflow:hidden;
      isolation:isolate;
      background:
        linear-gradient(180deg, rgba(6,26,58,.96) 0%, rgba(6,26,58,.72) 22%, rgba(6,26,58,.86) 100%),
        linear-gradient(140deg, rgba(255,196,0,.08), rgba(255,196,0,0) 48%),
        url("../resources/thearena.jpg") center/cover no-repeat;
    }

    #partners.aa-partners2-breakout .aa-partners2::before{
      content:"";
      position:absolute;
      inset:0;
      z-index:0;
      pointer-events:none;
      background:
        radial-gradient(circle at 16% 20%, rgba(255,196,0,.12), transparent 24%),
        radial-gradient(circle at 82% 24%, rgba(255,255,255,.08), transparent 18%),
        radial-gradient(circle at 50% 88%, rgba(0,0,0,.32), transparent 42%);
    }

    #partners.aa-partners2-breakout .aa-partners2::after{
      content:"";
      position:absolute;
      z-index:0;
      pointer-events:none;
      inset: 0;
      display: none;
    }

    #partners .aa-partners2__lines{
      position:absolute;
      inset:0;
      z-index:1;
      pointer-events:none;
      opacity:.18;
      background:
        repeating-linear-gradient(135deg, rgba(255,196,0,.18) 0px, rgba(255,196,0,.18) 1px, transparent 1px, transparent 24px),
        repeating-linear-gradient(45deg, rgba(245,247,250,.045) 0px, rgba(245,247,250,.045) 1px, transparent 1px, transparent 42px);
      mask-image:radial-gradient(900px 650px at 62% 34%, black 0%, black 54%, transparent 78%);
      -webkit-mask-image:radial-gradient(900px 650px at 62% 34%, black 0%, black 54%, transparent 78%);
      mix-blend-mode:screen;
    }

    #partners .aa-partners2__dust{
      position:absolute;
      inset:0;
      z-index:1;
      pointer-events:none;
      opacity:.18;
      background-image:
        radial-gradient(circle at 12% 24%, rgba(255,196,0,.24) 0 1px, transparent 2px),
        radial-gradient(circle at 28% 68%, rgba(245,247,250,.18) 0 1px, transparent 2px),
        radial-gradient(circle at 48% 34%, rgba(255,196,0,.14) 0 1px, transparent 2px),
        radial-gradient(circle at 68% 72%, rgba(245,247,250,.16) 0 1px, transparent 2px),
        radial-gradient(circle at 86% 28%, rgba(255,196,0,.16) 0 1px, transparent 2px);
      background-size:520px 520px;
      mix-blend-mode:screen;
    }

    #partners .aa-partners2__inner{
      position:relative;
      z-index:4;
      max-width:1320px;
      margin:0 auto;
      padding:0 22px;
    }

    #partners .aa-partners2__head{
      position:relative;
      max-width:900px;
      margin:0 auto 42px;
      text-align:center;
    }

    #partners .aa-partners2__head::after{
      content:"";
      position:absolute;
      left:50%;
      bottom:-22px;
      width:min(560px, 80vw);
      height:1px;
