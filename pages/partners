      align-items:center;
      justify-content:center;
      overflow:hidden;
    }

    #partners .aa-partnerBoard__logoStage::before{
      content:"";
      position:absolute;
      inset:-40%;
      background:
        radial-gradient(closest-side, rgba(255,196,0,.24), rgba(255,196,0,0) 68%),
        radial-gradient(closest-side, rgba(6,26,58,.18), rgba(6,26,58,0) 70%);
