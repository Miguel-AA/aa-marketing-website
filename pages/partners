    }

    #partners .aa-partners2__foot{
      margin-top:26px;
      padding-top:20px;
      border-top:1px solid rgba(245,247,250,.10);
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      flex-wrap:wrap;
      position:relative;
    }

    #partners .aa-partners2__foot::before{
      content:"";
      position:absolute;
      left:0;
      top:-1px;
      width:180px;
      height:1px;
      background:linear-gradient(90deg, rgba(255,196,0,.88), rgba(255,196,0,0));
    }

    #partners .aa-partners2__note{
      font-family:Inter, system-ui, sans-serif;
      color:rgba(245,247,250,.78);
      font-size:14px;
      line-height:1.6;
