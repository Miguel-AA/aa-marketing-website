    #partners .aa-partners2__cta:hover{
      transform:translateY(-2px);
      opacity:.98;
      box-shadow:0 24px 60px rgba(0,0,0,.32), 0 16px 40px rgba(255,196,0,.22);
    }

    #partners, #partners *{ outline:none !important; }
    #partners a:focus, #partners a:focus-visible,
    #partners button:focus, #partners button:focus-visible{
      outline:none !important;
      box-shadow:none !important;
    }
    #partners .aa-partnerTile:focus-visible,
    #partners .aa-partnerBoard__arrow:focus-visible{
      box-shadow:0 0 0 3px rgba(255,196,0,.52), 0 22px 60px rgba(0,0,0,.25) !important;
    }

    @media (max-width: 980px){
      #partners .aa-partnerBoard{ grid-template-columns:1fr; }
      #partners .aa-partnerBoard__logos{ min-height:0; }
    }

    @media (max-width: 640px){
      #partners.aa-partners2-breakout .aa-partners2{ padding:86px 0 82px; }
      #partners .aa-partners2__head{ margin-bottom:34px; }
      #partners .aa-partners2__title{ font-size:clamp(32px, 10vw, 46px); }
      #partners .aa-partnerBoard__logos{
        display:flex;
        overflow-x:auto;
        scroll-snap-type:x mandatory;
      }
      #partners .aa-partnerTile{
        min-width:176px;
        min-height:132px;
        scroll-snap-align:start;
      }
      #partners .aa-partnerBoard__feature{ padding:18px 16px; }
      #partners .aa-partners2__cta{ width:100%; }
    }
