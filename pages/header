<section class="aa-header-breakout">
  <header class="aa-header" role="banner">
    <div class="aa-header__inner">

      <!-- LOGO -->
      <a class="aa-brand" href="#home" aria-label="A&A Marketing home">
        <img
          src="../logo/aa_headerlogo.png"
          alt="A&A Marketing"
          class="aa-brand__logo"
        />
        <span class="aa-brand__wordmark" aria-hidden="true">
          <span class="aa-brand__name">A&amp;A Marketing</span>
          <span class="aa-brand__sub">Agency</span>
        </span>
      </a>

      <!-- NAV -->
      <nav class="aa-nav" aria-label="Primary navigation">
        <a href="#home">Home</a>
        <a href="#services">Services</a>
        <a href="#clients">Clients</a>
        <a href="#team">Team</a>
        <a href="#contact">Contact</a>
      </nav>

      <!-- CTA -->
      <a class="aa-cta" href="#contact" aria-label="Get in touch">
        <span class="aa-cta__label">Get in Touch</span>
        <span class="aa-cta__icon" aria-hidden="true">&rarr;</span>
      </a>

    </div>
  </header>

  <style>
    .aa-header-breakout{
      width: 100vw;
      margin-left: -50vw;
      left: 50%;
      position: sticky;
      top: 0;
      z-index: 9999;
    }

    .aa-header{
      min-height: 112px;
      padding: 16px 0;
      display: flex;
      align-items: center;
      background:
        linear-gradient(180deg, rgba(3,13,31,.96) 0%, rgba(6,26,58,.78) 100%);
      border-bottom: 1px solid rgba(255,196,0,.14);
      box-shadow: 0 22px 60px rgba(0,0,0,.24);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
    }

    .aa-header__inner{
      width: calc(100% - 36px);
      max-width: 1360px;
      height: 78px;
      margin: 0 auto;
      padding: 0 12px 0 16px;
      display: grid;
      grid-template-columns: minmax(230px, 1fr) auto minmax(190px, 1fr);
      align-items: center;
      gap: 20px;
      border: 1px solid rgba(245,247,250,.10);
      border-radius: 8px;
      background:
        linear-gradient(135deg, rgba(245,247,250,.095), rgba(245,247,250,.035));
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.08),
        0 18px 44px rgba(0,0,0,.26);
    }

    .aa-brand{
      min-width: 0;
      display: inline-flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
    }

    .aa-brand__logo{
      width: 72px;
      height: auto;
      display: block;
      object-fit: contain;
      filter: drop-shadow(0 10px 18px rgba(0,0,0,.28));
      flex: 0 0 auto;
    }

    .aa-brand__wordmark{
      display: grid;
      gap: 2px;
      min-width: 0;
    }

    .aa-brand__name,
    .aa-brand__sub{
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .aa-brand__name{
      color: #F5F7FA;
      font-size: 13px;
      font-weight: 900;
      letter-spacing: .08em;
      line-height: 1;
    }

    .aa-brand__sub{
      color: rgba(255,196,0,.92);
      font-size: 10px;
      font-weight: 800;
      letter-spacing: .22em;
      line-height: 1;
    }

    .aa-nav{
      justify-self: center;
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 7px;
      border: 1px solid rgba(245,247,250,.09);
      border-radius: 8px;
      background: rgba(2,10,26,.34);
    }

    .aa-nav a{
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .10em;
      text-transform: uppercase;
      color: rgba(245,247,250,.82);
      text-decoration: none;
      line-height: 1;
      padding: 12px 14px;
      border-radius: 6px;
      transition: color .18s ease, background .18s ease, transform .18s ease;
    }

    .aa-nav a:hover,
    .aa-nav a:focus-visible{
      color: #fff;
      background: rgba(255,196,0,.13);
      transform: translateY(-1px);
      outline: none;
    }

    .aa-cta{
      justify-self: end;
      height: 48px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      color: #061A3A;
      text-decoration: none;
      padding: 0 10px 0 17px;
      border-radius: 8px;
      border: 1px solid rgba(255,196,0,.58);
      background: linear-gradient(135deg, #FFC400 0%, #FFDA57 100%);
      box-shadow: 0 14px 34px rgba(255,196,0,.22), 0 12px 30px rgba(0,0,0,.22);
      transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
      white-space: nowrap;
    }

    .aa-cta__label{
      font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .14em;
      text-transform: uppercase;
      line-height: 1;
    }

    .aa-cta__icon{
      width: 26px;
      height: 26px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 6px;
      background: rgba(6,26,58,.13);
      font-size: 15px;
      line-height: 1;
    }

    .aa-cta:hover,
    .aa-cta:focus-visible{
      transform: translateY(-2px);
      filter: saturate(1.06);
      box-shadow: 0 18px 42px rgba(255,196,0,.28), 0 16px 36px rgba(0,0,0,.24);
      outline: none;
    }

    @media (max-width: 1100px){
      .aa-header__inner{
        grid-template-columns: auto 1fr auto;
        gap: 12px;
      }

      .aa-nav{
        gap: 2px;
      }

      .aa-nav a{
        padding: 10px 9px;
        letter-spacing: .08em;
      }
    }

    @media (max-width: 900px){
      .aa-header{
        min-height: 86px;
        padding: 10px 0;
      }

      .aa-header__inner{
        width: calc(100% - 24px);
        height: 64px;
        grid-template-columns: 1fr auto;
      }

      .aa-brand__logo{
        width: 58px;
      }

      .aa-nav{
        display: none;
      }

      .aa-cta{
        height: 42px;
      }
    }

    @media (max-width: 520px){
      .aa-header__inner{
        padding-left: 10px;
      }

      .aa-brand__wordmark{
        display: none;
      }

      .aa-brand__logo{
        width: 54px;
      }

      .aa-cta{
        width: 42px;
        padding: 0;
      }

      .aa-cta__label{
        display: none;
      }
    }
  </style>
</section>
