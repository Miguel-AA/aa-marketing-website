      dotsWrap.innerHTML = CLIENTS.map((_, i) =>
        `<button class="aa-dot" type="button" aria-label="Go to client ${i+1}" data-aa-dot="${i}"></button>`
      ).join("");

      const dots = Array.from(dotsWrap.querySelectorAll('.aa-dot'));
      let index = 0;

      const clampIndex = (i) => (i + CLIENTS.length) % CLIENTS.length;

      function setActiveDot(){
        dots.forEach((d, i) => d.classList.toggle('is-active', i === index));
      }

      function goTo(i, animate=true){
        index = clampIndex(i);
        track.style.transitionDuration = animate ? '.55s' : '0s';
        track.style.transform = `translate3d(${-index * 100}%, 0, 0)`;
        setActiveDot();
      }

      const AUTOPLAY_MS = 5200;
      let timer = null;
      const start = () => { stop(); timer = setInterval(() => goTo(index + 1, true), AUTOPLAY_MS); };
      const stop = () => { if(timer){ clearInterval(timer); timer = null; } };

      if(prevBtn) prevBtn.addEventListener('click', () => { goTo(index - 1, true); start(); });
      if(nextBtn) nextBtn.addEventListener('click', () => { goTo(index + 1, true); start(); });

      dotsWrap.addEventListener('click', (e) => {
        const b = e.target.closest('[data-aa-dot]');
        if(!b) return;
        goTo(parseInt(b.getAttribute('data-aa-dot'), 10), true);
        start();
      });

      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', start);

      let startX = 0, dx = 0, isDown = false;
      const onDown = (x) => { isDown = true; startX = x; dx = 0; stop(); track.style.transitionDuration = '0s'; };
      const onMove = (x) => {
        if(!isDown) return;
        dx = x - startX;
        const pct = (dx / root.clientWidth) * 100;
        track.style.transform = `translate3d(${(-index * 100) + pct}%, 0, 0)`;
      };
      const onUp = () => {
        if(!isDown) return;
        isDown = false;
        const threshold = Math.min(80, root.clientWidth * 0.18);
        if(dx > threshold) index = clampIndex(index - 1);
        else if(dx < -threshold) index = clampIndex(index + 1);
        goTo(index, true);
        start();
      };

      root.addEventListener('pointerdown', (e) => onDown(e.clientX));
      window.addEventListener('pointermove', (e) => onMove(e.clientX), { passive: true });
      window.addEventListener('pointerup', onUp, { passive: true });
      window.addEventListener('pointercancel', onUp, { passive: true });

      goTo(0, false);
      start();
      window.addEventListener('resize', () => goTo(index, false), { passive: true });
    })();
