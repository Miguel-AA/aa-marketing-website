    tag:"Automotive",
    logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Nissan_2020_logo.svg",
    desc:"Automotive collaborations and large-scale brand activations."
  },
  {
    name:"Pepsi",
    tag:"Beverage",
    logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Pepsi_logo_%282014%29.svg",
    desc:"Global consumer campaigns and high-reach sponsorship exposure."
  },
  {
    name:"Gatorade",
    tag:"Sports Drink",
    logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Gatorade_logo.svg",
    desc:"Global performance partnership & athlete activations."
  },
  {
    name:"Gibson",
    tag:"Music",
    logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Gibson_logo.svg",
    desc:"Iconic culture partnerships and premium storytelling moments."
  },
  {
    name:"Zoom",
    tag:"Technology",
    logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Zoom_Logo_2022.svg",
    desc:"Communications partner for campaigns and live collaborations."
  },
  {
    name:"Digicel",
    tag:"Telecom",
    logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Digicel_logo.svg",
    desc:"Regional brand activations + high-reach media exposure."
  },

  /* Celldration: no encontrÃ© un SVG â€œoficialâ€ limpio y estable como los demÃ¡s.
     Te dejo un placeholder SIN fondo (data URI). Si me pasas el logo oficial (PNG/SVG),
     te lo pongo aquÃ­ y ya. */
  {
    name:"Celldration",
    tag:"Hydration",
    logo:"data:image/svg+xml;utf8," + encodeURIComponent(`
      <svg xmlns="http://www.w3.org/2000/svg" width="900" height="240" viewBox="0 0 900 240">
        <defs>
          <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#FFC400"/>
            <stop offset="1" stop-color="#061A3A"/>
          </linearGradient>
        </defs>
        <g fill="none">
          <text x="12" y="132" font-family="Inter,Arial" font-weight="900" font-size="86" letter-spacing="1">
            <tspan fill="#F5F7FA">CELL</tspan><tspan fill="#FFC400">DRATION</tspan>
          </text>
          <path d="M770 16 C822 86 860 130 860 170 C860 215 825 240 770 240 C715 240 680 215 680 170 C680 130 718 86 770 16 Z"
                fill="url(#g)" opacity="0.95"/>
        </g>
      </svg>
    `),
    desc:"Consumer campaigns and endorsement alignment."
  }
];


      // Build slides (full-width, one at a time)
      track.innerHTML = PARTNERS.map((p, idx) => `
        <article class="aa-partners2__slide" role="group" aria-roledescription="slide" aria-label="${idx+1} of ${PARTNERS.length}">
          <div class="aa-partners2__logoPlate">
            <img class="aa-partners2__logo" src="${p.logo}" alt="${p.name} logo" loading="${idx===0 ? 'eager' : 'lazy'}" decoding="async">
          </div>

          <div class="aa-partners2__copyBox">
            <div class="aa-partners2__tagRow">
              <div class="aa-partners2__tag">${p.tag}</div>
            </div>

            <h3 class="aa-partners2__name">${p.name}</h3>
            <p class="aa-partners2__desc">${p.desc}</p>
          </div>
        </article>
      `).join("");

      // Mini row (quick select tabs)
      miniRow.innerHTML = PARTNERS.map((p, i) => `
        <button class="aa-miniBtn" type="button" data-aa-mini="${i}" aria-label="Go to ${p.name}">
          <span class="aa-miniDot" aria-hidden="true"></span>
          <span class="aa-miniText">${p.name}</span>
        </button>
      `).join("");

      const miniBtns = Array.from(miniRow.querySelectorAll('[data-aa-mini]'));

      let index = 0;
      const clampIndex = (i) => (i + PARTNERS.length) % PARTNERS.length;

      function setActive(){
        miniBtns.forEach((b, i) => b.classList.toggle('is-active', i === index));
        bar.style.width = ((index + 1) / PARTNERS.length * 100) + '%';
      }

      function goTo(i, animate=true){
        index = clampIndex(i);
        track.style.transitionDuration = animate ? '.65s' : '0s';
        track.style.transform = `translate3d(${-index * 100}%, 0, 0)`;
        setActive();
      }

      // Autoplay
      const AUTOPLAY_MS = 5200;
      let timer = null;
      const start = () => { stop(); timer = setInterval(() => goTo(index + 1, true), AUTOPLAY_MS); };
      const stop = () => { if(timer){ clearInterval(timer); timer = null; } };

      if(prevBtn) prevBtn.addEventListener('click', () => { goTo(index - 1, true); start(); });
      if(nextBtn) nextBtn.addEventListener('click', () => { goTo(index + 1, true); start(); });

      miniRow.addEventListener('click', (e) => {
        const b = e.target.closest('[data-aa-mini]');
        if(!b) return;
        goTo(parseInt(b.getAttribute('data-aa-mini'), 10), true);
        start();
      });

      // Pause on hover
      root.addEventListener('mouseenter', stop);
      root.addEventListener('mouseleave', start);

      // Swipe
      let startX = 0, dx = 0, isDown = false;
      const onDown = (x) => { isDown = true; startX = x; dx = 0; stop(); track.style.transitionDuration = '0s'; };
      const onMove = (x) => {
        if(!isDown) return;
        dx = x - startX;
        const pct = (dx / root.clientWidth) * 100;
        track.style.transform = `translate3d(${(-index * 100) + pct}%, 0, 0)`;
      };
      const onUp = () => {
        if(!isDown) return;
        isDown = false;
        const threshold = Math.min(90, root.clientWidth * 0.18);
        if(dx > threshold) index = clampIndex(index - 1);
        else if(dx < -threshold) index = clampIndex(index + 1);
        goTo(index, true);
        start();
      };

      root.addEventListener('pointerdown', (e) => onDown(e.clientX));
      window.addEventListener('pointermove', (e) => onMove(e.clientX), { passive: true });
      window.addEventListener('pointerup', onUp, { passive: true });
      window.addEventListener('pointercancel', onUp, { passive: true });

      // Init
      goTo(0, false);
      start();
      window.addEventListener('resize', () => goTo(index, false), { passive: true });

