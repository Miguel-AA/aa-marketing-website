        return `
          <article class="aa-clientSlide" role="group" aria-roledescription="slide" aria-label="${idx+1} of ${CLIENTS.length}">
            <div class="aa-clientSlide__media">
              <img class="aa-clientSlide__img" src="${c.image}" alt="${c.name}" loading="${idx===0 ? 'eager' : 'lazy'}" decoding="async"
