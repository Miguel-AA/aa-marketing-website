  <script>
    (function(){
      const scope = document.getElementById('services');
      if(!scope) return;

      const root = scope.querySelector('.aa-services2__grid');
      if(!root) return;

      const mode = root.getAttribute('data-aa-accordion') || 'single';
      const items = Array.from(root.querySelectorAll('[data-aa-acc]'));

      function closeItem(item){
        const btn = item.querySelector('.aa-acc__btn');
        const panel = item.querySelector('.aa-acc__panel');
        item.classList.remove('aa-open');
        if(btn) btn.setAttribute('aria-expanded', 'false');
        if(panel){
          panel.setAttribute('aria-hidden', 'true');
          panel.style.maxHeight = '0px';
        }
      }

      function openItem(item){
        const btn = item.querySelector('.aa-acc__btn');
        const panel = item.querySelector('.aa-acc__panel');
        item.classList.add('aa-open');
        if(btn) btn.setAttribute('aria-expanded', 'true');
        if(panel){
          panel.setAttribute('aria-hidden', 'false');
          panel.style.maxHeight = (panel.scrollHeight + 40) + 'px';
        }
      }

      // init closed
      items.forEach(closeItem);

      root.addEventListener('click', function(e){
        const btn = e.target.closest('.aa-acc__btn');
        if(!btn) return;
        const item = btn.closest('[data-aa-acc]');
        if(!item) return;

        const isOpen = item.classList.contains('aa-open');

        if(mode === 'single'){
          items.forEach(i => { if(i !== item) closeItem(i); });
        }

        if(isOpen) closeItem(item);
        else openItem(item);
      });

      // recompute open heights on resize
      window.addEventListener('resize', function(){
        items.forEach(item => {
          if(!item.classList.contains('aa-open')) return;
          const panel = item.querySelector('.aa-acc__panel');
          if(panel) panel.style.maxHeight = (panel.scrollHeight + 40) + 'px';
        });
      }, { passive: true });

      // Extra: prevent theme adding focus classes on mousedown (common)
      root.addEventListener('mousedown', function(e){
        const btn = e.target.closest('.aa-acc__btn');
        if(btn) btn.blur();
      });
    })();
  </script>
