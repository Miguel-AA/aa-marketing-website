      const prevBtn = scope.querySelector('[data-aa-prev]');
      const nextBtn = scope.querySelector('[data-aa-next]');
      const bar = scope.querySelector('[data-aa-bar]');
      const miniRow = scope.querySelector('[data-aa-minirow]');
      if(!root || !track || !bar || !miniRow) return;

      /* =========================
         PARTNERS (EDIT ONLY URLS)
         ========================= */
const PARTNERS = [
  {
    name:"Hublot",
    tag:"Luxury",
    logo:"https://commons.wikimedia.org/wiki/Special:FilePath/Hublot%20logo.svg",
    desc:"Premium positioning and brand storytelling for elite talent."
